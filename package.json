		"react-dom": "^19.2.0",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/canvas-confetti": "^1.9.0",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.1.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.0",
		"vite": "^7.2.0"
	}
}
