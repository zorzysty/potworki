		"@types/canvas-confetti": "^1.9.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
